# ====== LLM 配置（OpenAI 兼容接口，可指向 DeepSeek / Ark 豆包 / 自托管 vLLM / OpenAI） ======
# 若用 DeepSeek：LLM_BASE_URL=https://api.deepseek.com/v1                 LLM_MODEL=deepseek-chat
# 若用 Ark 豆包：LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3    LLM_MODEL=ep-20240xxx-xxxxx 或 doubao-pro-32k
# 若用自托管 vLLM：LLM_BASE_URL=http://vllm:8000/v1                       LLM_MODEL=Qwen/Qwen2.5-72B-Instruct-AWQ
# 若用 OpenAI：   LLM_BASE_URL=https://api.openai.com/v1                  LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-key
LLM_MODEL=deepseek-chat

# 嵌入后端：api | local
# - api  ：走 OpenAI 兼容 embeddings API，用 LLM_EMBED_MODEL
# - local：本地 sentence-transformers，零外部调用，首次自动下载权重
#   需要额外装：pip install sentence-transformers
EMBED_BACKEND=api

# 嵌入模型名（EMBED_BACKEND=api 时）
# - OpenAI：text-embedding-3-small 或 text-embedding-3-large
# - 豆包/Ark：在控制台创建 "embedding" 类型的 endpoint，填 ep-xxx
# - 自托管：vLLM / TEI 起 bge-m3 之类
LLM_EMBED_MODEL=text-embedding-3-small

# 本地嵌入模型（EMBED_BACKEND=local 时，HuggingFace 路径）
# - BAAI/bge-small-zh-v1.5：中英双语，512 维，~100MB（推荐入门）
# - BAAI/bge-m3：多语言多粒度，~2GB，质量更好
EMBED_LOCAL_MODEL=BAAI/bge-small-zh-v1.5

# 本地 RAG ------------------------------------------------------
# 默认关。开之后 Retriever 会在 OpenAlex 旁边并发查 RAG_INDEX_PATH 指向的 pickle 索引。
# 索引由 scripts/build_index.py 离线生成，比如：
#   python scripts/build_index.py ./docs
RAG_ENABLED=false
RAG_INDEX_PATH=rag_index.pkl
RAG_TOP_K=5

# 是否启用 response_format={"type":"json_object"} 强制 JSON 输出。
# OpenAI / DeepSeek 支持良好，设 true 能让 Planner/Reader/Reflector 更稳。
# 火山方舟 Ark（豆包）部分 endpoint 不认这个参数，会 5xx / 假 ModelLoading —— 保持 false。
# 默认 false：用 lenient JSON 解析兜底（抓 ```json``` 块或首个 {} 段）。
LLM_JSON_MODE=false

# Agent 运行时上限（避免死循环和超额 token 消耗）
AGENT_MAX_STEPS=4           # Planner→Retriever→Reader→Synthesizer 的最大循环轮数
AGENT_TOP_K=8               # 每次检索保留的论文数
AGENT_REFLECT=true          # 是否启用反思节点（不够就再搜一轮）

# OpenAlex（免费无需 key，但建议填邮箱进入 "polite pool" 获得更高速率）
OPENALEX_MAILTO=you@example.com

# 前端如何访问后端（docker-compose 内部网络用 http://api:8000；浏览器访问用 http://localhost:8000）
NEXT_PUBLIC_API_BASE=http://localhost:8000
